# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Vite ビルド成果物（Wordmove でデプロイする一時生成物）
/release

# Composer 依存（vendor は composer.json/lock から再現）
/vendor

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# webpとavifは自動生成する
src/assets/webp
src/assets/avif

# -------------------------------------------
# WordPress 本体（コア）は追跡しない。wp-content 配下のみ追跡する
# （コアのバージョンは docker-compose.yml の image タグで管理）
# -------------------------------------------
/wordpress/*
!/wordpress/wp-content/
/wordpress/wp-content/*
!/wordpress/wp-content/plugins/
!/wordpress/wp-content/mu-plugins/
!/wordpress/wp-content/uploads/

# テーマは src/ で開発するため、wp-content/themes 配下（同梱の既定テーマ等）は追跡しない

# プラグインは既定で追跡しない（無料プラグインは Composer=composer.json/lock で管理・再現）
/wordpress/wp-content/plugins/*
!/wordpress/wp-content/plugins/.gitkeep
# 有料/手動管理プラグインだけ個別に追跡する（設置ごとに1行ずつ追加）
# 例: !/wordpress/wp-content/plugins/advanced-custom-fields-pro/

# 自動生成されるViteサーバー定義
/src/config/vite-server-config.php
/src/config/theme-env.php


# 環境設定ファイル
.env
